---
import type { LocaleCode } from '@/utils/i18n'
import BaseLayout from './BaseLayout.astro'
import TopNavbar from '@/components/TopNavbar.astro'
import Footer from '@/components/Footer.astro'

interface Props {
  locale: LocaleCode
  title: string
  description: string
  jsonLd?: Record<string, unknown>
  isHeroPage?: boolean
  fullWidth?: boolean
}

const { locale, title, description, jsonLd, isHeroPage = false, fullWidth = false } = Astro.props
---

<BaseLayout locale={locale} title={title} description={description} jsonLd={jsonLd}>
  <slot name="head" slot="head" />

  {isHeroPage ? (
    <slot name="hero" />
    <main transition:animate="fade">
      <slot />
    </main>
  ) : (
    <>
      <TopNavbar locale={locale} />
      <main class:list={[fullWidth ? 'px-5 md:px-16 py-6' : 'container mx-auto max-w-5xl px-4 py-6']} transition:animate="fade">
        <slot />
      </main>
    </>
  )}

  <div transition:animate="none">
    <Footer locale={locale} fullWidth={fullWidth || isHeroPage} />
  </div>
</BaseLayout>
