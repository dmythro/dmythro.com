---
import { availableLocales, type LocaleCode } from '@/utils/i18n'
import { ELocaleNames } from 'my-constants'

interface Props {
  locale: LocaleCode
}

const { locale } = Astro.props
const currentPath = Astro.url.pathname.replace(`/${locale}`, '') || '/'
---

<div class="dropdown dropdown-end">
  <div tabindex="0" role="button" class="btn btn-ghost btn-sm gap-1">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 512 512">
      <path d="M352 256c0 22.2-1.2 43.6-3.3 64H163.3c-2.2-20.4-3.3-41.8-3.3-64s1.2-43.6 3.3-64h185.4c2.2 20.4 3.3 41.8 3.3 64zm28.8-64h123.1c5.3 20.5 8.1 41.9 8.1 64s-2.8 43.5-8.1 64H380.8c2.1-20.6 3.2-42 3.2-64s-1.1-43.4-3.2-64zm112.6-32H376.7c-10-63.9-29.8-117.4-55.3-151.6C378.8 32.2 425.1 81 456.8 144h36.6zM317.4 32.4c29.5 38.4 52.1 97.3 62.3 175.6H132.3c10.2-78.3 32.8-137.2 62.3-175.6C210 17.6 228.9 8 256 8c27.1 0 46 9.6 61.4 24.4zM55.2 160c31.7-63 78-111.8 135.4-135.6C165.1 58.6 145.3 112.1 135.3 176H8.1c5.3-5.7 16-16 47.1-16zm-47 224h127.1c10 63.9 29.8 117.4 55.3 151.6C133.2 479.8 86.9 431 55.2 368H8.1zm129.2 0h237.4c-10.2 78.3-32.8 137.2-62.3 175.6C296 558.4 277.1 568 256 568c-21.1 0-40-9.6-55.4-24.4C171 505.2 147.5 446.3 137.3 368z" />
    </svg>
    <span class="hidden sm:inline">{ELocaleNames[locale]}</span>
  </div>
  <ul tabindex="0" class="dropdown-content menu bg-base-200 rounded-box z-50 w-40 p-2 shadow">
    {availableLocales.map((l) => (
      <li>
        <a
          href={`/${l}${currentPath}`}
          hreflang={l}
          class:list={[{ active: l === locale }]}
        >
          {ELocaleNames[l]}
        </a>
      </li>
    ))}
  </ul>
</div>
