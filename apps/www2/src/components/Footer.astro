---
import { Linkedin } from '@lucide/astro'
import { Github, Threads, X } from 'simple-icons-astro'
import { footerLinks } from '@/data/profile'
import { getT } from '@/utils/getT'
import type { LocaleCode } from '@/utils/i18n'

interface Props {
  locale: LocaleCode
  fullWidth?: boolean
}

const { locale, fullWidth = false } = Astro.props
const t = getT(locale)
const year = new Date().getFullYear()

const iconMap: Record<string, typeof Github> = {
  github: Github,
  twitter: X,
  threads: Threads,
  linkedin: Linkedin,
}
---

<footer class:list={[
  'footer py-8 text-base-content/60 no-print',
  fullWidth ? 'px-5 md:px-16' : 'container mx-auto max-w-5xl px-4',
]}>
  <div class="w-full flex flex-row justify-between items-center gap-4">
    <div class="text-sm">
      &copy; {year} Dmythro &middot;
      <a href={`/${locale}/built-with`} class="link link-hover">{t.builtWith}</a>
    </div>
    <div class="flex items-center gap-4">
      {footerLinks.map(({ id, title, href }) => {
        const Icon = iconMap[id]
        return Icon && (
          <a
            href={href}
            class="opacity-80 hover:opacity-100 transition-opacity"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={title}
            title={title}
          >
            <Icon class="size-4" />
          </a>
        )
      })}
    </div>
  </div>
</footer>