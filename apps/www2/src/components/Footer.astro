---
import { USERNAME } from '@dmythro/constants'

import { footerLinks } from '@/data/profile'
import type { LocaleCode } from '@/utils/i18n'

interface Props {
  locale: LocaleCode
  fullWidth?: boolean
}

const { locale, fullWidth = false } = Astro.props
const year = new Date().getFullYear()
---

<footer class:list={[
  'footer py-8 text-base-content/60 no-print',
  fullWidth ? 'px-5 md:px-16' : 'container mx-auto max-w-5xl px-4',
]}>
  <div class="w-full flex flex-col md:flex-row md:justify-between md:items-center gap-4">
    <div class="text-sm">
      &copy; {year} {USERNAME.replace('@', '')}
    </div>
    <div class="flex items-center gap-6">
      {footerLinks.map(({ title, href }) => (
        <a
          href={href}
          class="link link-hover text-sm"
          target="_blank"
          rel="noopener noreferrer"
        >
          {title}
        </a>
      ))}
    </div>
  </div>
</footer>
