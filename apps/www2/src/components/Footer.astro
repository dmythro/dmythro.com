---
import { USERNAME } from '@dmythro/constants'

import { footerLinks } from '@/data/profile'
import type { LocaleCode } from '@/utils/i18n'

interface Props {
  locale: LocaleCode
}

const { locale } = Astro.props
const year = new Date().getFullYear()
---

<footer class="footer py-8 px-5 md:px-16 text-base-content/60 no-print">
  <div class="max-w-6xl mx-auto w-full flex flex-col items-center gap-4">
    <div class="flex items-center gap-6">
      {footerLinks.map(({ title, href }) => (
        <a
          href={href}
          class="link link-hover text-sm"
          target="_blank"
          rel="noopener noreferrer"
        >
          {title}
        </a>
      ))}
    </div>
    <div class="text-sm">
      &copy; {year} {USERNAME.replace('@', '')}
    </div>
  </div>
</footer>
