---
// 3-state theme toggle: System → Dark → Light → System
import { Monitor, Moon, Sun } from '@lucide/astro'
---

<button
  id="theme-toggle"
  class="btn btn-ghost btn-sm btn-square"
  type="button"
  aria-label="Toggle theme"
>
  {/* System icon */}
  <span class="theme-icon theme-icon-system">
    <Monitor class="h-5 w-5" />
  </span>
  {/* Sun icon (light) */}
  <span class="theme-icon theme-icon-light hidden">
    <Sun class="h-5 w-5" />
  </span>
  {/* Moon icon (dark) */}
  <span class="theme-icon theme-icon-dark hidden">
    <Moon class="h-5 w-5" />
  </span>
</button>

<script is:inline>
  ;(function () {
    const btn = document.getElementById('theme-toggle')
    if (!btn) return

    function getEffectiveTheme(mode) {
      if (mode === 'system') {
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
      }
      return mode
    }

    function applyTheme(mode) {
      var theme = getEffectiveTheme(mode)
      document.documentElement.setAttribute('data-theme', theme)
      document.documentElement.classList.toggle('dark', theme === 'dark')
    }

    function updateIcon(mode) {
      var icons = btn.querySelectorAll('.theme-icon')
      for (var i = 0; i < icons.length; i++) {
        icons[i].classList.add('hidden')
      }
      btn.querySelector('.theme-icon-' + mode).classList.remove('hidden')
    }

    var saved = localStorage.getItem('theme-mode') || 'system'
    // Migrate from old 'theme' key
    if (!localStorage.getItem('theme-mode')) {
      var old = localStorage.getItem('theme')
      if (old) {
        saved = old
        localStorage.setItem('theme-mode', old)
        localStorage.removeItem('theme')
      }
    }

    applyTheme(saved)
    updateIcon(saved)

    var cycle = { system: 'dark', dark: 'light', light: 'system' }
    btn.addEventListener('click', function () {
      saved = cycle[saved] || 'system'
      localStorage.setItem('theme-mode', saved)
      applyTheme(saved)
      updateIcon(saved)
    })

    // Listen for system preference changes when in system mode
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function () {
      if (saved === 'system') applyTheme('system')
    })
  })()
</script>
