---
// 3-state theme toggle: System → Dark → Light → System
import { Monitor, Moon, Sun } from '@lucide/astro'

interface Props {
  labels: { system: string; dark: string; light: string }
}

const { labels } = Astro.props
---

<div class="tooltip tooltip-left tooltip-primary" data-tip={labels.system} id="theme-toggle-tip">
  <button
    id="theme-toggle"
    class="btn btn-ghost btn-sm btn-square"
    type="button"
    aria-label={labels.system}
    data-label-system={labels.system}
    data-label-dark={labels.dark}
    data-label-light={labels.light}
  >
    {/* System icon */}
    <span class="theme-icon theme-icon-system">
      <Monitor class="h-5 w-5" />
    </span>
    {/* Sun icon (light) */}
    <span class="theme-icon theme-icon-light hidden">
      <Sun class="h-5 w-5" />
    </span>
    {/* Moon icon (dark) */}
    <span class="theme-icon theme-icon-dark hidden">
      <Moon class="h-5 w-5" />
    </span>
  </button>
</div>

<script is:inline>
  ;(() => {
    const btn = document.getElementById('theme-toggle')
    const tipEl = document.getElementById('theme-toggle-tip')
    if (!btn) return

    const labelMap = {
      system: btn.dataset.labelSystem,
      dark: btn.dataset.labelDark,
      light: btn.dataset.labelLight,
    }

    const getEffectiveTheme = (mode) =>
      mode === 'system'
        ? window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
        : mode

    const applyTheme = (mode) => {
      const theme = getEffectiveTheme(mode)
      document.documentElement.setAttribute('data-theme', theme)
      document.documentElement.classList.toggle('dark', theme === 'dark')
    }

    const updateIcon = (mode) => {
      for (const icon of btn.querySelectorAll('.theme-icon')) {
        icon.classList.add('hidden')
      }
      btn.querySelector(`.theme-icon-${mode}`)?.classList.remove('hidden')
      if (tipEl) tipEl.setAttribute('data-tip', labelMap[mode])
      btn.setAttribute('aria-label', labelMap[mode])
    }

    let saved = localStorage.getItem('theme-mode') || 'system'
    // Migrate from old 'theme' key
    if (!localStorage.getItem('theme-mode')) {
      const old = localStorage.getItem('theme')
      if (old) {
        saved = old
        localStorage.setItem('theme-mode', old)
        localStorage.removeItem('theme')
      }
    }

    applyTheme(saved)
    updateIcon(saved)

    const cycle = { system: 'dark', dark: 'light', light: 'system' }
    btn.addEventListener('click', () => {
      saved = cycle[saved] || 'system'
      localStorage.setItem('theme-mode', saved)
      applyTheme(saved)
      updateIcon(saved)
    })

    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
      if (saved === 'system') applyTheme('system')
    })
  })()
</script>
