---
import { ESocialLinks } from '@dmythro/constants'
import { ArrowRight, FileText, Infinity as InfinityIcon, Package } from '@lucide/astro'
import { Github } from 'simple-icons-astro'
import type { AggregateStats } from '@/utils/fetchAggregateStats'
import { getT } from '@/utils/getT'
import type { LocaleCode } from '@/utils/i18n'

interface Props {
  locale: LocaleCode
  stats: AggregateStats
}

const { locale, stats } = Astro.props
const t = getT(locale)
const paragraphs = t.cv.description(stats.yearsExperience)

const statItems = [
  {
    value: `${stats.yearsExperience}+`,
    label: t.landing.stats.years,
    icon: '' as const,
    href: `/${locale}/cv`,
    gradient: 'from-primary/15 to-secondary/10',
    border: 'border-primary/20 hover:border-primary/50',
    shadow: 'shadow-[0_0_20px_rgba(99,102,241,0.1)]',
  },
  {
    value: '∞',
    label: t.landing.stats.linesOfCode,
    icon: '' as const,
    href: `/${locale}/projects`,
    gradient: 'from-secondary/15 to-primary/10',
    border: 'border-secondary/20 hover:border-secondary/50',
    shadow: 'shadow-[0_0_20px_rgba(139,92,246,0.1)]',
  },
  {
    value: `${stats.totalDownloadsFormatted}+`,
    label: t.landing.stats.downloads,
    icon: 'npm' as const,
    href: 'https://www.npmjs.com/~dmythro',
    gradient: 'from-accent/15 to-primary/10',
    border: 'border-accent/20 hover:border-accent/50',
    shadow: 'shadow-[0_0_20px_rgba(34,211,238,0.1)]',
  },
  {
    value: `${stats.totalStarsFormatted}+`,
    label: t.landing.stats.stars,
    icon: 'github' as const,
    href: ESocialLinks.github,
    gradient: 'from-primary/15 to-accent/10',
    border: 'border-primary/20 hover:border-primary/50',
    shadow: 'shadow-[0_0_20px_rgba(99,102,241,0.1)]',
  },
]
---

<section class="py-16 px-5 md:px-16">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold mb-8">{t.landing.tldr}</h2>
    <div class="flex flex-col-reverse md:flex-row gap-8">
      {/* Text content */}
      <div class="flex-1 space-y-4">
        {paragraphs.map((p, i) => (
          <p class:list={['text-lg leading-relaxed', i === 0 ? 'text-base-content/80' : 'text-base-content/60']}>
            {p}
          </p>
        ))}
        <a href={`/${locale}/cv`} class="inline-flex items-center gap-1.5 mt-2 text-primary font-semibold text-sm hover:text-primary/80 transition-colors">
          <FileText class="h-4 w-4" />
          {t.landing.cvLink}
        </a>
      </div>

      {/* Stats grid */}
      <div class="w-full md:w-95 md:shrink-0 grid grid-cols-2 gap-3">
        {statItems.map(({ value, label, icon, href, gradient, border, shadow }) => (
          <a
            href={href}
            class:list={[
              'card p-5',
              `bg-linear-to-br ${gradient}`,
              `border ${border}`,
              shadow,
            ]}
            target={href.startsWith('http') ? '_blank' : undefined}
            rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
          >
            <span class="block text-4xl font-extrabold bg-linear-to-r from-primary to-accent bg-clip-text text-transparent">
              {value === '∞' ? (
                <InfinityIcon class="h-12 w-12 -my-1 stroke-[2.5] stroke-primary" />
              ) : value}
            </span>
            <span class="mt-2 text-xs text-base-content/70">
              {icon === 'npm' && <Package class="h-3.5 w-3.5 inline align-[-0.1875rem]" aria-label="NPM" role="img" /> }
              {icon === 'github' && <Github class="h-3.5 w-3.5 inline align-[-0.1875rem]" aria-label="GitHub" role="img" /> }
              {icon && ' '}{label}&nbsp;<ArrowRight class="h-3 w-3 inline align-[-0.125rem]" />
            </span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
