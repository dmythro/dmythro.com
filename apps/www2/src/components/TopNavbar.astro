---
import { ArrowDown, FileText, FolderOpen, House, Mail, Menu, X } from '@lucide/astro'
import { USERNAME } from '@dmythro/constants'

import { getT } from '@/utils/getT'
import { availableLocales, type LocaleCode } from '@/utils/i18n'
import { ELocaleNames } from '@dmythro/constants'

import ThemeToggle from './ThemeToggle.astro'

interface Props {
  locale: LocaleCode
}

const { locale } = Astro.props
const t = getT(locale)
const currentPath = Astro.url.pathname
const localePathSuffix = currentPath.replace(`/${locale}`, '') || '/'

const navItems = [
  { id: 'home', label: t.nav.home, href: `/${locale}/`, Icon: House },
  { id: 'projects', label: t.nav.projects, href: `/${locale}/projects`, Icon: FolderOpen },
  { id: 'cv', label: t.nav.cv, href: `/${locale}/cv`, Icon: FileText },
  { id: 'contact', label: t.nav.contact, href: `/${locale}/contact`, Icon: Mail },
]

function isActive(href: string): boolean {
  if (href.endsWith('/')) {
    return currentPath === href
  }
  return currentPath.startsWith(href)
}

const otherLocale = availableLocales.find((l) => l !== locale) || locale
---

<header
  class="bg-base-200 backdrop-blur-xl border-b border-[var(--color-border,theme(colors.base-300))] z-50 no-print sticky top-0"
  id="main-navbar"
>
  <input id="nav-drawer" type="checkbox" class="hidden peer" />

  {/* Scroll hint — pulsing arrow, visible only when hero avatar is on screen */}
  <div
    id="navbar-scroll-hint"
    class="absolute left-1/2 -translate-x-1/2 top-1/2 -translate-y-1/2 pointer-events-none opacity-0 transition-opacity duration-300 hidden lg:block"
  >
    <ArrowDown class="h-6 w-6 text-[var(--color-content-secondary)] animate-pulse" />
  </div>

  <div class="flex items-center justify-between h-16 px-4 md:px-16">
    {/* Identity — left */}
    <a href={`/${locale}/`} class="flex items-center gap-3 shrink-0 overflow-hidden">
      {/* Avatar — collapses when hero avatar is visible */}
      <div
        id="navbar-avatar-wrap"
        class="w-11 h-11 rounded-full overflow-hidden border-2 border-indigo-300 shrink-0 transition-all duration-300 ease-out"
      >
        <img src="/avatar@40px.webp" alt={USERNAME} width="44" height="44" class="w-full h-full object-cover" />
      </div>
      <div class="flex flex-col gap-0.5">
        <span class="text-lg font-semibold lowercase leading-tight">
          <span class="text-base-content/50 font-thin">@</span>{USERNAME.replace('@', '')}
        </span>
        <span class="text-xs text-[var(--color-content-secondary)] hidden sm:inline leading-tight">{t.meta.descriptionShort}</span>
      </div>
    </a>

    {/* Right side — nav items + divider + utilities */}
    <div class="hidden lg:flex items-stretch h-full">
      {navItems.map(({ id, label, href, Icon }) => {
        const active = isActive(href)
        return id === 'home' ? (
          <a
            href={href}
            class:list={[
              'flex items-center justify-center px-4 transition-colors border-b-2',
              active
                ? 'bg-gradient-to-b from-[#6366F120] to-[#6366F108] border-primary'
                : 'border-transparent hover:bg-base-300/30',
            ]}
            aria-label={label}
          >
            <Icon class:list={['h-[18px] w-[18px]', active ? 'text-primary' : 'text-[var(--color-content-secondary)]']} />
          </a>
        ) : (
          <a
            href={href}
            class:list={[
              'flex items-center justify-center px-4 text-sm transition-colors border-b-2',
              active
                ? 'bg-gradient-to-b from-[#6366F120] to-[#6366F108] border-primary text-primary font-semibold'
                : 'border-transparent text-[var(--color-content-secondary)] font-medium hover:text-base-content hover:bg-base-300/30',
            ]}
          >
            {label}
          </a>
        )
      })}

      {/* Divider */}
      <div class="flex items-center pl-4">
        <div class="w-px h-6 bg-[var(--color-border,theme(colors.base-300))]"></div>
      </div>

      {/* Utilities */}
      <div class="flex items-center gap-4 pl-4 pr-1">
        <ThemeToggle />
        <a
          href={`/${otherLocale}${localePathSuffix}`}
          hreflang={otherLocale}
          class="text-[13px] font-semibold text-[var(--color-content-secondary)] hover:text-base-content transition-colors"
        >
          {ELocaleNames[locale].slice(0, 2).toUpperCase()}
        </a>
      </div>
    </div>

    {/* Mobile: hamburger */}
    <label for="nav-drawer" class="btn btn-ghost btn-square lg:hidden" aria-label={t.actions.openMenu}>
      <Menu class="h-5 w-5" />
    </label>
  </div>

  {/* Mobile drawer */}
  <div class="fixed inset-0 z-40 hidden peer-checked:block lg:hidden">
    <label for="nav-drawer" class="fixed inset-0 bg-black/30"></label>
    <div class="fixed right-0 top-0 h-full w-64 bg-base-100 shadow-xl p-4">
      <label for="nav-drawer" class="btn btn-ghost btn-sm btn-square float-right mb-4" aria-label={t.actions.closeMenu}>
        <X class="h-5 w-5" />
      </label>
      <ul class="menu w-full clear-both gap-1">
        {navItems.map(({ label, href, Icon }) => (
          <li>
            <a href={href} class:list={['gap-1.5', isActive(href) && 'active']}>
              <Icon class="h-4 w-4" />
              {label}
            </a>
          </li>
        ))}
        <li class="mt-2 border-t border-base-300 pt-2">
          <a href={`/${otherLocale}${localePathSuffix}`} hreflang={otherLocale}>
            {ELocaleNames[otherLocale]}
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>

{/* Show/hide navbar avatar + scroll hint based on hero avatar visibility */}
<script is:inline>
  ;(function () {
    var wrap = document.getElementById('navbar-avatar-wrap')
    var hint = document.getElementById('navbar-scroll-hint')
    var heroAvatar = document.getElementById('hero-avatar')
    if (!wrap) return

    function hideAvatar() {
      wrap.style.width = '0'
      wrap.style.opacity = '0'
      wrap.style.borderWidth = '0'
      wrap.style.marginRight = '-12px'
      if (hint) hint.style.opacity = '0.6'
    }

    function showAvatar() {
      wrap.style.width = ''
      wrap.style.opacity = ''
      wrap.style.borderWidth = ''
      wrap.style.marginRight = ''
      if (hint) hint.style.opacity = '0'
    }

    if (!heroAvatar) {
      showAvatar()
      return
    }

    // Start hidden (hero avatar is visible on load)
    hideAvatar()

    var observer = new IntersectionObserver(
      function (entries) {
        if (entries[0].isIntersecting) {
          hideAvatar()
        } else {
          showAvatar()
        }
      },
      { threshold: 0 }
    )
    observer.observe(heroAvatar)
  })()
</script>
