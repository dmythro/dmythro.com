---
import { Image } from 'astro:assets'
import { ArrowDown, ChevronRight, FileText, FolderOpen, House, Mail, Menu } from '@lucide/astro'
import { ELocaleNames, USERNAME } from '@dmythro/constants'

import avatarSmall from '@/assets/avatar@40px.webp'

import { getT } from '@/utils/getT'
import { availableLocales, type LocaleCode } from '@/utils/i18n'

import ThemeToggle from './ThemeToggle.astro'

interface Props {
  locale: LocaleCode
}

const { locale } = Astro.props
const t = getT(locale)
const currentPath = Astro.url.pathname
const localePathSuffix = currentPath.replace(`/${locale}`, '') || ''

const navItems = [
  { id: 'home', label: t.nav.home, href: `/${locale}`, Icon: House },
  { id: 'cv', label: t.nav.cv, href: `/${locale}/cv`, Icon: FileText },
  { id: 'projects', label: t.nav.projects, href: `/${locale}/projects`, Icon: FolderOpen },
  { id: 'contact', label: t.nav.contact, href: `/${locale}/contact`, Icon: Mail },
]

function isActive(href: string): boolean {
  if (href === `/${locale}`) {
    return currentPath === href || currentPath === `${href}/`
  }
  return currentPath.startsWith(href)
}

const otherLocale = availableLocales.find((l) => l !== locale) || locale
---

<header
  class="bg-base-200 backdrop-blur-xl border-b border-[var(--color-border,theme(colors.base-300))] z-50 no-print sticky top-0"
  id="main-navbar"
>
  {/* Scroll hint — pulsing arrow, visible only when hero avatar is on screen */}
  <div
    id="navbar-scroll-hint"
    class="absolute left-1/2 -translate-x-1/2 top-1/2 -translate-y-1/2 pointer-events-none opacity-0 transition-opacity duration-300 hidden lg:block"
  >
    <ArrowDown class="h-6 w-6 text-[var(--color-content-secondary)] animate-pulse" />
  </div>

  <div class="flex items-center justify-between h-16 px-4 md:px-16">
    {/* Identity — left */}
    <a href={`/${locale}`} class="flex items-center gap-3 shrink-0 overflow-hidden">
      {/* Avatar — collapses when hero avatar is visible */}
      <div
        id="navbar-avatar-wrap"
        class="w-11 h-11 rounded-full overflow-hidden border-2 border-indigo-300 shrink-0 transition-all duration-300 ease-out"
      >
        <Image src={avatarSmall} alt={USERNAME} width={44} height={44} class="w-full h-full object-cover" />
      </div>
      <div class="flex flex-col gap-0.5">
        <span class="text-lg font-semibold lowercase leading-tight">
          <span class="text-base-content/50 font-thin">@</span>{USERNAME.replace('@', '')}
        </span>
        <span class="text-xs text-[var(--color-content-secondary)] hidden sm:inline leading-tight">{t.meta.descriptionShort}</span>
      </div>
    </a>

    {/* Right side — nav items + divider + utilities */}
    <div class="hidden lg:flex items-stretch h-full">
      {navItems.map(({ id, label, href, Icon }) => {
        const active = isActive(href)
        return id === 'home' ? (
          <a
            href={href}
            class:list={[
              'flex items-center justify-center px-4 transition-colors border-b-2',
              active
                ? 'bg-gradient-to-b from-[#6366F120] to-[#6366F108] border-primary'
                : 'border-transparent hover:bg-base-300/30',
            ]}
            aria-label={label}
          >
            <Icon class:list={['h-[18px] w-[18px]', active ? 'text-primary' : 'text-[var(--color-content-secondary)]']} />
          </a>
        ) : (
          <a
            href={href}
            class:list={[
              'flex items-center justify-center px-4 text-sm transition-colors border-b-2',
              active
                ? 'bg-gradient-to-b from-[#6366F120] to-[#6366F108] border-primary text-primary font-semibold'
                : 'border-transparent text-[var(--color-content-secondary)] font-medium hover:text-base-content hover:bg-base-300/30',
            ]}
          >
            {label}
          </a>
        )
      })}

      {/* Divider */}
      <div class="flex items-center pl-4">
        <div class="w-px h-6 bg-[var(--color-border,theme(colors.base-300))]"></div>
      </div>

      {/* Utilities */}
      <div class="flex items-center gap-4 pl-4 pr-1">
        <ThemeToggle labels={{
          system: t.actions.themeSystem,
          dark: t.actions.themeDark,
          light: t.actions.themeLight,
        }} />
        <div class="tooltip tooltip-left tooltip-primary" data-tip={t.actions.switchLang}>
          <a
            href={`/${otherLocale}${localePathSuffix}`}
            hreflang={otherLocale}
            aria-label={t.actions.switchLang}
            class="text-[13px] font-semibold text-[var(--color-content-secondary)] hover:text-base-content transition-colors"
          >
            {ELocaleNames[locale].slice(0, 2).toUpperCase()}
          </a>
        </div>
      </div>
    </div>

    {/* Mobile: hamburger — uses Popover API for click-outside-to-close */}
    <button
      id="burger-toggle"
      class="btn btn-ghost btn-square lg:hidden"
      aria-label={t.actions.openMenu}
      style="anchor-name:--burger-btn"
    >
      <Menu class="h-5 w-5" />
    </button>
  </div>
</header>

{/* Backdrop — captures clicks so they don't pass through to page elements */}
<div id="burger-backdrop" class="fixed inset-0 z-[999] hidden"></div>

{/* Mobile menu — popover renders in top layer, no stacking context issues */}
<div
  id="burger-menu"
  popover="manual"
  class="dropdown w-[280px] rounded-xl shadow-[0_8px_32px_rgba(0,0,0,0.15)] backdrop-blur-2xl border border-base-300 bg-base-200/90 p-0 m-0"
  style="position-anchor:--burger-btn;"
>
  {/* Nav links */}
  <nav class="p-2">
    {navItems.filter(({ id }) => id !== 'home').map(({ label, href, Icon }) => {
      const active = isActive(href)
      return (
        <a
          href={href}
          class:list={[
            'flex items-center gap-3 px-3 h-12 rounded-lg transition-colors',
            active
              ? 'bg-base-300/50 text-primary'
              : 'text-base-content hover:bg-base-300/25',
          ]}
        >
          <Icon class:list={['h-[18px] w-[18px]', active ? 'text-primary' : 'text-[var(--color-content-secondary)]']} />
          <span class="flex-1 text-sm font-medium">{label}</span>
          <ChevronRight class="h-4 w-4 text-[var(--color-content-muted)]" />
        </a>
      )
    })}
  </nav>

  {/* Divider */}
  <div class="mx-3 border-t border-base-300"></div>

  {/* Language section */}
  <div class="p-2">
    <div class="px-3 py-1.5 text-xs font-medium text-[var(--color-content-muted)] uppercase tracking-wider">
      {t.actions.language}
    </div>
    {availableLocales.map((loc) => {
      const isCurrentLocale = loc === locale
      return (
        <a
          href={isCurrentLocale ? undefined : `/${loc}${localePathSuffix}`}
          hreflang={loc}
          class:list={[
            'flex items-center gap-3 px-3 h-10 rounded-lg transition-colors',
            isCurrentLocale ? 'text-base-content' : 'text-[var(--color-content-secondary)] hover:bg-base-300/25',
          ]}
        >
          <span class:list={[
            'w-4 h-4 rounded-full border-2 flex items-center justify-center shrink-0',
            isCurrentLocale ? 'border-primary' : 'border-[var(--color-content-muted)]',
          ]}>
            {isCurrentLocale && <span class="w-2 h-2 rounded-full bg-primary"></span>}
          </span>
          <span class="text-sm">{ELocaleNames[loc]}</span>
        </a>
      )
    })}
  </div>

  {/* Divider */}
  <div class="mx-3 border-t border-base-300"></div>

  {/* Theme section */}
  <div class="p-2 pb-3" id="burger-theme-section">
    <div class="px-3 py-1.5 text-xs font-medium text-[var(--color-content-muted)] uppercase tracking-wider">
      {t.actions.theme}
    </div>
    {(['system', 'dark', 'light'] as const).map((mode) => {
      const labels = {
        system: t.actions.themeSystem,
        dark: t.actions.themeDark,
        light: t.actions.themeLight,
      }
      return (
        <button
          type="button"
          data-theme-mode={mode}
          class="burger-theme-btn flex items-center gap-3 px-3 h-10 rounded-lg transition-colors text-[var(--color-content-secondary)] hover:bg-base-300/25 w-full text-left"
        >
          <span class="burger-theme-dot w-4 h-4 rounded-full border-2 border-[var(--color-content-muted)] flex items-center justify-center shrink-0">
          </span>
          <span class="text-sm">{labels[mode]}</span>
        </button>
      )
    })}
  </div>
</div>

{/* Show/hide navbar avatar + scroll hint based on hero avatar visibility */}
<script is:inline>
  ;(() => {
    const wrap = document.getElementById('navbar-avatar-wrap')
    const hint = document.getElementById('navbar-scroll-hint')
    const heroAvatar = document.getElementById('hero-avatar')
    if (!wrap) return

    const hideAvatar = () => {
      wrap.style.width = '0'
      wrap.style.opacity = '0'
      wrap.style.borderWidth = '0'
      wrap.style.marginRight = '-12px'
      if (hint) hint.style.opacity = '0.6'
    }

    const showAvatar = () => {
      wrap.style.width = ''
      wrap.style.opacity = ''
      wrap.style.borderWidth = ''
      wrap.style.marginRight = ''
      if (hint) hint.style.opacity = '0'
    }

    if (!heroAvatar) {
      showAvatar()
      return
    }

    hideAvatar()

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) hideAvatar()
        else showAvatar()
      },
      { threshold: 0 },
    )
    observer.observe(heroAvatar)
  })()
</script>

{/* Burger menu — manual popover open/close with backdrop */}
<script is:inline>
  ;(() => {
    const menu = document.getElementById('burger-menu')
    const backdrop = document.getElementById('burger-backdrop')
    const toggleBtn = document.getElementById('burger-toggle')
    if (!menu || !backdrop || !toggleBtn) return

    const open = () => {
      backdrop.classList.remove('hidden')
      menu.showPopover()
    }

    const close = () => {
      backdrop.classList.add('hidden')
      menu.hidePopover()
    }

    toggleBtn.addEventListener('click', (e) => {
      e.preventDefault()
      if (menu.matches(':popover-open')) close()
      else open()
    })

    backdrop.addEventListener('click', (e) => {
      e.preventDefault()
      e.stopPropagation()
      close()
    })

    menu.addEventListener('toggle', (e) => {
      if (e.newState === 'closed') backdrop.classList.add('hidden')
    })

    for (const link of menu.querySelectorAll('a[href]')) {
      link.addEventListener('click', () => close())
    }
  })()
</script>

{/* Burger menu theme switcher */}
<script is:inline>
  ;(() => {
    const buttons = document.querySelectorAll('.burger-theme-btn')
    if (!buttons.length) return

    const getEffectiveTheme = (mode) =>
      mode === 'system'
        ? window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
        : mode

    const applyTheme = (mode) => {
      const theme = getEffectiveTheme(mode)
      document.documentElement.setAttribute('data-theme', theme)
      document.documentElement.classList.toggle('dark', theme === 'dark')
    }

    const PRIMARY = 'oklch(0.5457 0.2124 264.05)'

    const updateBurgerDots = (currentMode) => {
      for (const btn of buttons) {
        const mode = btn.getAttribute('data-theme-mode')
        const dot = btn.querySelector('.burger-theme-dot')
        if (mode === currentMode) {
          dot.style.borderColor = PRIMARY
          dot.innerHTML = `<span class="w-2 h-2 rounded-full" style="background:${PRIMARY}"></span>`
        } else {
          dot.style.borderColor = ''
          dot.innerHTML = ''
        }
      }
    }

    const updateThemeToggleIcon = (mode) => {
      const toggle = document.getElementById('theme-toggle')
      if (!toggle) return
      for (const icon of toggle.querySelectorAll('.theme-icon')) {
        icon.classList.add('hidden')
      }
      toggle.querySelector(`.theme-icon-${mode}`)?.classList.remove('hidden')
    }

    const saved = localStorage.getItem('theme-mode') || 'system'
    updateBurgerDots(saved)

    for (const btn of buttons) {
      btn.addEventListener('click', () => {
        const mode = btn.getAttribute('data-theme-mode')
        localStorage.setItem('theme-mode', mode)
        applyTheme(mode)
        updateBurgerDots(mode)
        updateThemeToggleIcon(mode)
      })
    }
  })()
</script>
