---
import type { InterestKey, InterestLocale } from '@dmythro/locales'
import { ESocialLinks } from '@dmythro/constants'
import faqEn from '@dmythro/locales/mdx/faq.en.md?raw'
import faqUk from '@dmythro/locales/mdx/faq.uk.md?raw'
import hobbiesEn from '@dmythro/locales/mdx/hobbies.en.md?raw'
import hobbiesUk from '@dmythro/locales/mdx/hobbies.uk.md?raw'
import {
  Bike,
  Book,
  Briefcase,
  CircleQuestionMark,
  Cpu,
  Gamepad2,
  Headphones,
  Link,
  MapPin,
} from '@lucide/astro'
import { Hash, Linkedin as LucideLinkedin } from '@lucide/astro'
import { Bluesky, Facebook, Github, Instagram, Telegram, Threads, X } from 'simple-icons-astro'
import { Image } from 'astro:assets'

import studioImg from '@/assets/my-studio.webp'
import { fetchGithubStats } from '@/utils/fetchGithubStats'
import { fetchNpmStats, formatNumber } from '@/utils/fetchNpmStats'
import { getT } from '@/utils/getT'
import type { LocaleCode } from '@/utils/i18n'

import Stats from './Stats.astro'
import Timeline from './Timeline.astro'

interface Props {
  locale: LocaleCode
}

const { locale } = Astro.props
const t = getT(locale)
const interestList = Object.keys(t.interests) as InterestKey[]

const sectionIcons: Record<string, typeof Briefcase> = {
  webDev: Briefcase,
  music: Headphones,
  travel: MapPin,
  hobbies: Gamepad2,
  faq: CircleQuestionMark,
  links: Link,
}

const mdxKeyMap: Record<string, string> = {
  webDev: 'web-dev',
  music: 'music',
  travel: 'travel',
  hobbies: 'hobbies',
}

// Load MDX content
const mdxFiles = import.meta.glob('../../../../packages/locales/mdx/*.md', {
  eager: true,
}) as Record<string, { compiledContent(): string }>

// Fetch live stats at build time
const [npmStats, ghStats] = await Promise.all([
  fetchNpmStats('countries-list'),
  fetchGithubStats('annexare/Countries', 1300),
])

const starsFormatted = `~${formatNumber(ghStats.stars)}`
const downloadsFormatted = `${formatNumber(npmStats.downloads)}+/mo`

function replaceStats(html: string): string {
  return html
    .replace(/~1\.3[kк]\s*/gi, `${starsFormatted} `)
    .replace(/1\.5M\+\/mo/gi, downloadsFormatted)
    .replace(/1\.5M\+\s*зкачувань на місяць/gi, `${downloadsFormatted} завантажень на місяць`)
}

// Pre-resolve all MDX content (compiledContent is async)
const mdxContent: Partial<Record<string, string>> = {}
for (const [interestKey, fileName] of Object.entries(mdxKeyMap)) {
  const key = Object.keys(mdxFiles).find((k) => k.endsWith(`/${fileName}.${locale}.md`))
  if (!key) continue
  const html = await mdxFiles[key].compiledContent()
  mdxContent[interestKey] = replaceStats(html)
}

// FAQ parsing
const rawFaq = locale === 'uk' ? faqUk : faqEn
type FaqItem = { question: string; answer: string }

const faqItems: FaqItem[] = rawFaq
  .split(/^## /m)
  .filter(Boolean)
  .map((block) => {
    const [question, ...rest] = block.split('\n')
    const answer = rest.join('\n').trim()
    return { question: question.trim(), answer }
  })

// Hobbies parsing — intro + cards
const rawHobbies = locale === 'uk' ? hobbiesUk : hobbiesEn
const hobbiesParts = rawHobbies.split(/^## /m)
const hobbiesIntro = hobbiesParts[0].trim()
const hobbyIconMap: Record<string, typeof Cpu> = {
  0: Cpu,
  1: Bike,
  2: Book,
  3: Gamepad2,
}
const hobbyCards = hobbiesParts.slice(1).map((block, i) => {
  const [title, ...rest] = block.split('\n')
  return { title: title.trim(), body: rest.join('\n').trim(), Icon: hobbyIconMap[i] }
})

// Social links (contact-style with icons)
const socialLinks = [
  {
    title: 'GitHub',
    href: ESocialLinks.github,
    description: t.socialMedia[ESocialLinks.github],
    Icon: Github,
    color: 'currentColor',
  },
  {
    title: 'LinkedIn',
    href: ESocialLinks.linkedin,
    description: t.socialMedia[ESocialLinks.linkedin],
    Icon: LucideLinkedin,
    color: '#0A66C2',
  },
  {
    title: 'X / Twitter',
    href: ESocialLinks.twitter,
    description: t.socialMedia[ESocialLinks.twitter],
    Icon: X,
    color: 'currentColor',
  },
  {
    title: 'Threads',
    href: ESocialLinks.threads,
    description: t.socialMedia[ESocialLinks.threads],
    Icon: Threads,
    color: 'currentColor',
  },
  {
    title: 'Instagram',
    href: ESocialLinks.instagram,
    description: t.socialMedia[ESocialLinks.instagram],
    Icon: Instagram,
    color: '#E4405F',
  },
  {
    title: 'Facebook',
    href: ESocialLinks.facebook,
    description: t.socialMedia[ESocialLinks.facebook],
    Icon: Facebook,
    color: '#0866FF',
  },
  {
    title: 'Telegram',
    href: ESocialLinks.telegram,
    description: t.socialMedia[ESocialLinks.telegram],
    Icon: Telegram,
    color: '#26A5E4',
  },
  {
    title: 'BlueSky',
    href: ESocialLinks.bluesky,
    description: t.socialMedia[ESocialLinks.bluesky],
    Icon: Bluesky,
    color: '#0285FF',
  },
  {
    title: 'Nostr',
    href: ESocialLinks.nostr,
    description: t.socialMedia[ESocialLinks.nostr],
    Icon: Hash,
    color: '#8B5CF6',
  },
]

const sections = interestList.map((key) => {
  const interest = t.interests[key] as InterestLocale
  const Icon = sectionIcons[key]
  return { key, interest, Icon, mdxHtml: mdxContent[key] }
})

const lastKey = interestList[interestList.length - 1]
---

<article class="flex flex-col gap-16 print:gap-6">
  {sections.map(({ key, interest, Icon, mdxHtml }) => (
    <section id={key} class="scroll-mt-24 print:break-before-page">
      <div class="flex items-start gap-3 mb-4">
        <div class="flex-1">
          <h2 class="text-xl font-bold">{interest.title}</h2>
          {interest.description && (
            <p class="text-sm text-base-content/60">{interest.description}</p>
          )}
        </div>
        {Icon && <Icon class="h-6 w-6 text-primary shrink-0 mt-1" />}
      </div>

      {/* MDX prose content (skip hobbies — rendered as cards below) */}
      {mdxHtml && key !== 'hobbies' && (
        <div class="prose prose-sm max-w-none" set:html={mdxHtml} />
      )}

      {/* Hobbies — intro + cards */}
      {key === 'hobbies' && (
        <>
          <p class="text-sm text-base-content/80 mb-4">{hobbiesIntro}</p>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            {hobbyCards.map(({ title: cardTitle, body, Icon: CardIcon }) => (
              <div class="card bg-base-100 border border-base-300 p-4">
                <div class="flex items-start gap-3">
                  {CardIcon && <CardIcon class="h-5 w-5 text-primary shrink-0 mt-0.5" />}
                  <div>
                    <h3 class="font-semibold mb-1">{cardTitle}</h3>
                    <p class="text-sm text-base-content/70">{body.replace(/&mdash;/g, '—')}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </>
      )}

      {/* webDev extras */}
      {key === 'webDev' && (
        <>
          <figure class="my-4 rounded-lg overflow-hidden">
            <Image
              src={studioImg}
              alt={t.myStudio}
              class="w-full h-auto rounded-lg"
              loading="lazy"
            />
            <figcaption class="text-xs text-base-content/65 text-center py-1">
              {t.myStudio}
            </figcaption>
          </figure>

          <Stats id="skills" title={t.skillsTitle} items={t.skills} isExpanded={true} />
          <Timeline id="general-timeline" title={t.generalTitle} items={t.generalTimeline} />
          <Timeline id="career" title={t.careerTitle} items={t.careerTimeline} />
        </>
      )}

      {/* FAQ section */}
      {key === 'faq' && (
        <div class="flex flex-col gap-2">
          {faqItems.map(({ question, answer }, i) => (
            <div class="collapse collapse-arrow bg-base-100 border border-base-300 print:collapse-open">
              <input type="radio" name="faq-cv" checked={i === 0} aria-label={question} />
              <div class="collapse-title font-medium">{question}</div>
              <div class="collapse-content">
                <div class="prose prose-sm max-w-none" set:html={answer.replace(/\n\n/g, '<br><br>').replace(/`([^`]+)`/g, '<code>$1</code>')} />
              </div>
            </div>
          ))}
        </div>
      )}

      {/* Links section — contact-style cards with icons */}
      {key === 'links' && (
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-3">
          {socialLinks.map(({ title, href, description, Icon: SIcon, color }) => (
            <a
              href={href}
              target="_blank"
              rel="me noopener noreferrer"
              class="group flex items-center gap-4 p-4 rounded-xl border border-base-300 bg-base-100 hover:bg-base-200 transition-colors print:p-2 print:border-0"
            >
              <div class="shrink-0">
                <SIcon class="h-10 w-10 print:h-6 print:w-6" style={`color: ${color}`} />
              </div>
              <div class="flex-1 min-w-0">
                <div class="font-medium">{title}</div>
                <div class="text-sm text-content-secondary truncate">{description}</div>
              </div>
            </a>
          ))}
        </div>
      )}

      {/* Section divider (not on last) */}
      {key !== lastKey && (
        <hr class="mt-16 border-base-300/50 no-print" />
      )}
    </section>
  ))}
</article>

<style is:global>
  .prose a[href^="http"] {
    color: color-mix(in oklch, var(--color-primary) 85%, black);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: color-mix(in oklch, var(--color-primary) 30%, transparent);
    transition: color 0.15s, text-decoration-color 0.15s;
  }
  [data-theme='dark'] .prose a[href^="http"] {
    color: color-mix(in oklch, var(--color-primary) 75%, white);
  }
  .prose a[href^="http"]:hover {
    text-decoration-color: var(--color-primary);
  }
  .prose a[href^="http"] .link-icon {
    display: inline-block;
    width: 0.85em;
    height: 0.85em;
    vertical-align: -0.05em;
    margin-left: 0.25em;
    opacity: 0.7;
  }
</style>

