---
import { AtSign, Github, Linkedin, Twitter } from '@lucide/astro'

import { socialLinks } from '@/data/profile'
import { getT } from '@/utils/getT'
import type { LocaleCode } from '@/utils/i18n'

import TopNavbar from './TopNavbar.astro'

interface Props {
  locale: LocaleCode
}

const { locale } = Astro.props
const t = getT(locale)

const iconMap: Record<string, typeof Github> = {
  github: Github,
  twitter: Twitter,
  threads: AtSign,
  linkedin: Linkedin,
}
---

{/* Hero section — navbar height subtracted so hero + navbar = 100dvh */}
<section
  id="hero-section"
  class="h-[calc(100dvh-4rem)] flex flex-col items-center justify-center relative bg-gradient-to-br from-base-300 via-base-100 to-base-200 px-4"
>
  <div class="flex flex-col items-center text-center gap-8 max-w-2xl w-full">
    {/* Avatar with glow effect */}
    <div class="relative" id="hero-avatar">
      {/* Glow */}
      <div class="absolute inset-0 scale-[1.4] rounded-full bg-[radial-gradient(circle,rgba(99,102,241,0.25)_0%,rgba(139,92,246,0.15)_40%,transparent_70%)] blur-2xl"></div>
      {/* Avatar ring — slow spinning conic gradient */}
      <div class="avatar-ring relative w-40 h-40 md:w-[180px] md:h-[180px] rounded-full p-[3px]">
        <div class="w-full h-full rounded-full overflow-hidden">
          <img
            src="/avatar@400px.jpg"
            srcset="/avatar@400px.jpg 400w, /avatar@800px.jpg 800w"
            sizes="180px"
            alt={t.fullName}
            loading="eager"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>

    {/* Name — gradient text */}
    <h1 class="text-5xl md:text-6xl font-extrabold tracking-tighter bg-gradient-to-b from-white via-slate-200 to-indigo-200 bg-clip-text text-transparent">
      {t.fullName}
    </h1>

    {/* Role */}
    <p class="text-lg md:text-[22px] font-medium tracking-widest text-slate-400 uppercase -mt-3">
      Tech Lead / Principal Engineer
    </p>

    {/* One-liner */}
    <p class="text-[15px] text-slate-500 max-w-lg -mt-2">
      {t.landing.heroDescription}
    </p>

    {/* Social pills — circle icons, expand to pill with label on hover/focus */}
    <div class="flex flex-wrap gap-3 justify-center mt-2">
      {socialLinks.map(({ id, title, href }) => {
        const Icon = iconMap[id]
        return (
          <a
            href={href}
            class="social-pill group"
            target="_blank"
            rel="me noopener noreferrer"
            aria-label={title}
          >
            {Icon && <Icon class="h-6 w-6 shrink-0" />}
            <span class="social-pill-label">{title}</span>
          </a>
        )
      })}
    </div>
  </div>
</section>

<style>
  @property --ring-angle {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }

  .avatar-ring {
    background: conic-gradient(
      from var(--ring-angle),
      #6366F1,
      #8B5CF6,
      #22D3EE,
      #6366F1
    );
    animation: ring-spin 6s linear infinite;
  }

  @keyframes ring-spin {
    to {
      --ring-angle: 360deg;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .avatar-ring {
      animation: none;
      background: conic-gradient(from 0deg, #6366F1, #8B5CF6, #22D3EE, #6366F1);
    }
  }
</style>

{/* Navbar — right after hero, sticky so it sticks when scrolled to top */}
<TopNavbar locale={locale} />
