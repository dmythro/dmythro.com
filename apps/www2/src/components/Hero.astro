---
import { Image } from 'astro:assets'
import { ExternalLink, Info } from '@lucide/astro'
import { Github, Threads, X } from 'simple-icons-astro'
import avatarImg from '@/assets/avatar@800px.jpg'
import { socialLinks } from '@/data/profile'
import Linkedin from '@/icons/Linkedin.astro'
import { getT } from '@/utils/getT'
import type { LocaleCode } from '@/utils/i18n'
import TopNavbar from './TopNavbar.astro'

interface Props {
  locale: LocaleCode
}

const { locale } = Astro.props
const t = getT(locale)

const invasionStart = new Date('2022-02-24')
const today = new Date()
const daysSinceInvasion = Math.floor((today.getTime() - invasionStart.getTime()) / 86_400_000) + 1

const iconMap: Record<string, typeof Github> = {
  github: Github,
  twitter: X,
  threads: Threads,
  linkedin: Linkedin,
}
---

{/* Hero section — navbar height subtracted so hero + navbar = 100dvh */}
<section
  id="hero-section"
  class="min-h-[calc(100dvh-4rem)] flex flex-col items-center justify-center relative bg-linear-to-br from-base-300 via-base-100 to-base-200 px-4 py-8"
>
  <div class="flex flex-col items-center text-center gap-6 md:gap-10 max-w-2xl w-full">
    {/* Avatar with glow effect */}
    <div class="relative" id="hero-avatar" transition:name="hero-avatar" transition:animate="none">
      {/* Glow */}
      <div class="absolute inset-0 scale-[1.4] rounded-full bg-[radial-gradient(circle,rgba(99,102,241,0.25)_0%,rgba(139,92,246,0.15)_40%,transparent_70%)] blur-2xl"></div>
      {/* Avatar ring — slow spinning conic gradient */}
      <div class="avatar-ring relative size-52 md:size-64 rounded-full p-0.75">
        <div class="w-full h-full rounded-full overflow-hidden">
          <Image
            src={avatarImg}
            widths={[180, 360]}
            sizes="180px"
            alt={t.fullName}
            loading="eager"
            fetchpriority="high"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>

    {/* Name — gradient text */}
    <h1 class="text-5xl md:text-6xl font-extrabold tracking-tighter bg-linear-to-b from-primary/60 via-base-content/80 to-base-content bg-clip-text text-transparent px-1">
      {t.fullName}
    </h1>

    {/* Role */}
    <p class="text-lg md:text-[22px] font-medium tracking-widest text-base-content/60 uppercase -mt-3">
      Tech Lead / Principal Engineer
    </p>

    {/* One-liner */}
    <p class="text-[15px] text-base-content/50 max-w-lg -mt-2">
      {t.landing.heroDescription}
    </p>

    {/* Stand with Ukraine — dropdown opening upward */}
    <div class="dropdown dropdown-top -mt-4" data-ukraine-dropdown>
      <div tabindex="0" role="button" class="btn btn-soft btn-primary gap-2 px-5 py-2">
        <Info class="h-4 w-4" />
        #StandWithUkraine
        <svg class="h-4 w-6 rounded-sm" viewBox="0 0 60 40" aria-label="Ukrainian flag" role="img">
          <rect width="60" height="20" fill="#005BBB" />
          <rect y="20" width="60" height="20" fill="#FFD500" />
        </svg>
      </div>
      <div tabindex="0" class="dropdown-content bg-base-200 border border-base-300 rounded-xl shadow-lg p-4 w-80 mb-2 -translate-x-1/2 left-1/2">
        <p class="text-sm text-base-content/70 mb-3" data-days-counter>
          {t.supportUkraine.message(daysSinceInvasion)}
        </p>
        <a
          href="https://u24.gov.ua/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 text-sm text-primary hover:text-primary/80 transition-colors"
          data-ukraine-link
        >
          {t.supportUkraine.linkTitle}
          <ExternalLink class="h-3.5 w-3.5" />
        </a>
      </div>
    </div>

    {/* Social pills — circle icons, expand to pill with label on hover/focus */}
    <div class="flex flex-wrap gap-3 justify-center mt-2">
      {socialLinks.map(({ id, title, href }) => {
        const Icon = iconMap[id]
        return (
          <a
            href={href}
            class="social-pill group"
            target="_blank"
            rel="me noopener noreferrer"
            aria-label={title}
            data-social={id}
          >
            {Icon && <Icon class="h-6 w-6 shrink-0" />}
            <span class="social-pill-label">{title}</span>
          </a>
        )
      })}
    </div>
  </div>
</section>

<script>
  function getDaysSinceInvasion(): number {
    const now = new Date()
    const start = new Date(2022, 1, 24) // Feb 24, 2022 in local TZ
    const today = new Date(now.getFullYear(), now.getMonth(), now.getDate())
    return Math.round((today.getTime() - start.getTime()) / 86_400_000) + 1
  }

  function updateDaysCounter() {
    const el = document.querySelector('[data-days-counter]')
    if (!el) return
    const current = el.textContent ?? ''
    el.textContent = current.replace(/\d+/, String(getDaysSinceInvasion()))
  }

  function setupUkraineDropdown() {
    const dropdown = document.querySelector('[data-ukraine-dropdown]')
    if (!dropdown) return
    dropdown.addEventListener('focusin', () => {
      updateDaysCounter()
      window.zaraz?.track('stand_with_ukraine', { day: getDaysSinceInvasion() })
    })
    dropdown.querySelector('[data-ukraine-link]')?.addEventListener('click', () => {
      window.zaraz?.track('support_ukraine_click', { day: getDaysSinceInvasion() })
    })
    updateDaysCounter()
  }

  document.addEventListener('astro:page-load', setupUkraineDropdown)
</script>

<style>
  @property --ring-angle {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }

  .avatar-ring {
    background: conic-gradient(
      from var(--ring-angle),
      #6366F1,
      #8B5CF6,
      #22D3EE,
      #6366F1
    );
    animation: ring-spin 6s linear infinite;
  }

  @keyframes ring-spin {
    to {
      --ring-angle: 360deg;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .avatar-ring {
      animation: none;
      background: conic-gradient(from 0deg, #6366F1, #8B5CF6, #22D3EE, #6366F1);
    }
  }
</style>

{/* Navbar — right after hero, sticky so it sticks when scrolled to top */}
<TopNavbar locale={locale} isHeroPage />
