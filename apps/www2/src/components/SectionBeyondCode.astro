---
import { Image } from 'astro:assets'
import { Gamepad2, Headphones, MapPin } from '@lucide/astro'

import { profileImages } from '@/data/profile'
import { getT } from '@/utils/getT'
import type { LocaleCode } from '@/utils/i18n'

interface Props {
  locale: LocaleCode
}

const { locale } = Astro.props
const t = getT(locale)

const cards = [
  {
    image: profileImages.music,
    title: t.interests.music.title,
    subtitle: t.interests.music.subtitle,
    description: t.interests.music.description,
    Icon: Headphones,
    href: `/${locale}/cv#music`,
  },
  {
    image: profileImages.travel,
    title: t.interests.travel.title,
    subtitle: t.interests.travel.subtitle,
    description: t.interests.travel.description,
    Icon: MapPin,
    href: `/${locale}/cv#travel`,
  },
  {
    image: profileImages.studio,
    title: t.interests.hobbies.title,
    subtitle: t.interests.hobbies.subtitle,
    description: t.interests.hobbies.description,
    Icon: Gamepad2,
    href: `/${locale}/cv#hobbies`,
  },
]
---

<section class="py-16 px-5 md:px-16 bg-base-200/30">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold mb-2">{t.landing.beyondCode}</h2>
    <p class="text-base-content/60 mb-8">{t.landing.beyondCodeSubtitle}</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {cards.map(({ image, title, subtitle, description, Icon, href }) => (
        <a href={href} class="relative h-[280px] md:h-[360px] rounded-xl border border-base-300 overflow-hidden group block">
          <Image
            src={image}
            alt={title}
            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
          />
          {/* Caption pill */}
          <div class="absolute inset-x-0 bottom-0 p-4">
            <div class="rounded-lg backdrop-blur-3xl bg-[#0A0F1C]/50 p-3.5 px-4 flex items-start gap-2.5">
              <div class="shrink-0 mt-0.5 w-4">
                <Icon class="h-4 w-4 text-indigo-300" />
              </div>
              <div class="min-w-0">
                <p class="text-xs leading-tight">
                  <span class="font-bold text-neutral-content">{title}</span>
                  {subtitle && <span class="text-neutral-content/60"> · {subtitle}</span>}
                </p>
                <p class="text-xs leading-relaxed text-neutral-content/70 mt-1 line-clamp-2">{description}</p>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
