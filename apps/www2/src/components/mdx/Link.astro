  npm: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M1.763 0C.786 0 0 .786 0 1.763v20.474C0 23.214.786 24 1.763 24h20.474c.977 0 1.763-.786 1.763-1.763V1.763C24 .786 23.214 0 22.237 0zM5.13 5.323l13.837.019-.009 13.836h-3.464l.01-10.382h-3.456L12.04 19.17H5.113z"/></svg>',
  youtube:
    '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814"/><path fill="#fff" d="m9.545 15.568 6.272-3.568-6.272-3.568z"/></svg>',
  external:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>',
}

function getIcon(href: string): string {
  if (href.includes('github.com')) return icons.github
  if (href.includes('npmjs.com')) return icons.npm
  if (href.includes('youtu.be') || href.includes('youtube.com')) return icons.youtube
  return icons.external
}

const { href, ...rest } = Astro.props
const isExternal = href?.startsWith('http')
const icon = isExternal ? getIcon(href!) : null
---

{isExternal ? (
  <a href={href} target="_blank" rel="noopener noreferrer" {...rest}>
    <slot /><span class="link-icon" set:html={icon} />
  </a>
) : (
  <a href={href} {...rest}><slot /></a>
)}
