---
import { Package, Star } from '@lucide/astro'

import type { Project } from '@/data/projects'
import type { GithubStats } from '@/utils/fetchGithubStats'
import type { NpmStats } from '@/utils/fetchNpmStats'
import { formatNumber } from '@/utils/fetchNpmStats'
import type { LocaleCode } from '@/utils/i18n'

interface Props {
  project: Project
  locale: LocaleCode
  npm?: NpmStats | null
  github?: GithubStats | null
}

const { project, locale, npm, github } = Astro.props
const title = project.title[locale]
const description = project.description[locale]
const mainTags = project.tags.slice(0, 2)
---

<a
  href={`/${locale}/projects/${project.slug}`}
  class="card bg-base-100 border border-base-300 shadow-sm hover:shadow-md transition-shadow overflow-hidden"
>
  {project.image && (
    <figure>
      <img src={project.image} alt={title} class="w-full h-40 object-cover" loading="lazy" />
    </figure>
  )}
  <div class="card-body p-4 gap-2">
    <h3 class="card-title text-base">{title}</h3>
    <p class="text-sm text-base-content/60 line-clamp-2">{description}</p>

    {/* Stats badges */}
    {(npm || github) && (
      <div class="flex flex-wrap gap-1.5 mt-1">
        {npm && npm.downloads > 0 && (
          <span class="badge badge-sm badge-primary badge-outline gap-1">
            <Package class="h-3 w-3" /> {formatNumber(npm.downloads)}/mo
          </span>
        )}
        {github && github.stars > 0 && (
          <span class="badge badge-sm badge-warning badge-outline gap-1">
            <Star class="h-3 w-3" /> {formatNumber(github.stars)}
          </span>
        )}
      </div>
    )}

    {/* Tags — only main ones */}
    <div class="card-actions justify-start mt-1 flex-wrap gap-1">
      {mainTags.map((tag) => (
        <span class="badge badge-sm badge-ghost">{tag}</span>
      ))}
    </div>
  </div>
</a>
