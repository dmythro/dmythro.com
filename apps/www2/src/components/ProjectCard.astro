---
import { Image } from 'astro:assets'
import { Camera, Globe, Music, Package, Terminal } from '@lucide/astro'
import type { Project } from '@/data/projects'
import type { GithubStats } from '@/utils/fetchGithubStats'
import type { NpmStats } from '@/utils/fetchNpmStats'
import type { LocaleCode } from '@/utils/i18n'
import StatBadge from './StatBadge.astro'
import TagBadge from './TagBadge.astro'

interface Props {
  project: Project
  locale: LocaleCode
  npm?: NpmStats | null
  github?: GithubStats | null
}

const iconMap = {
  package: Package,
  globe: Globe,
  terminal: Terminal,
  music: Music,
  camera: Camera,
} as const
const { project, locale, npm, github } = Astro.props
const title = project.title[locale]
const IconComponent = iconMap[project.icon as keyof typeof iconMap]
const description = project.description[locale]
const statCount = (npm && npm.downloads > 0 ? 1 : 0) + (github && github.stars > 0 ? 1 : 0)
const displayTags = project.tags.filter((t) => t !== 'npm' && t !== 'open-source')
const mainTags = displayTags.slice(0, 5 - statCount)
---

<a
  href={`/${locale}/projects/${project.slug}`}
  class="card bg-base-100 border border-base-300 hover:border-primary/40 shadow-sm overflow-hidden"
>
  {project.image && (
    <figure>
      <Image src={project.image} alt={title} class="w-full h-40 object-cover" loading="lazy" inferSize />
    </figure>
  )}
  <div class="card-body p-4 gap-2">
    <h3 class="card-title text-base">
      {IconComponent && <IconComponent class="h-4 w-4 shrink-0 opacity-60" />}
      {title}
    </h3>
    <p class="text-sm text-base-content/60 line-clamp-4">{description}</p>

    <div class="flex flex-wrap gap-1 mt-1">
      {npm && npm.downloads > 0 && <StatBadge type="npm" value={npm.downloads} />}
      {github && github.stars > 0 && <StatBadge type="stars" value={github.stars} />}
      {mainTags.map((tag) => <TagBadge tag={tag} />)}
    </div>
  </div>
</a>
