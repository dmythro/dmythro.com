---
import { Image } from 'astro:assets'
import avatarLarge from '@/assets/avatar@800px.jpg'
import { getT } from '@/utils/getT'
import type { LocaleCode } from '@/utils/i18n'

interface Props {
  locale: LocaleCode
}

const { locale } = Astro.props
const t = getT(locale)
const years = new Date().getFullYear() - 2006
---

<div>
  <figure class="overflow-hidden">
    <Image
      src={avatarLarge}
      widths={[400, 800]}
      sizes="(max-width: 400px) 400px, 800px"
      alt={t.fullName}
      class="w-full h-auto rounded-lg"
      loading="eager"
      fetchpriority="high"
    />
    <figcaption class="text-xs text-base-content/50 text-center py-1.5">
      {t.fullName} — 📷 Alina Delyne
    </figcaption>
  </figure>

  {/* CV description — print only */}
  <div class="hidden print:block card bg-base-100 border border-base-300 rounded-md shadow-none mt-4 p-4">
    <p class="text-xl font-bold mb-3">{t.cv.title}</p>
    {t.cv.description(years).map((text) => (
      <p>{text}</p>
    ))}
  </div>
</div>
