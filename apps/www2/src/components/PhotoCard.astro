---
import type { LocaleCode } from '@/utils/i18n'
import { getT } from '@/utils/getT'

interface Props {
  locale: LocaleCode
}

const { locale } = Astro.props
const t = getT(locale)
const years = new Date().getFullYear() - 2006
---

<div>
  <figure class="rounded-xl overflow-hidden shadow-lg">
    <img
      src="/avatar@800px.jpg"
      srcset="/avatar@400px.jpg 400w, /avatar@800px.jpg 800w, /avatar.jpg 1200w"
      sizes="(max-width: 400px) 400px, (max-width: 800px) 800px, 1200px"
      alt={t.fullName}
      class="w-full h-auto"
      loading="eager"
      decoding="async"
    />
    <figcaption class="text-xs text-base-content/50 text-center py-1.5">
      {t.fullName} — 📷 Alina Delyne
    </figcaption>
  </figure>

  {/* CV description — print only */}
  <div class="hidden print:block card bg-base-100 border border-base-300 rounded-md shadow-none mt-4 p-4">
    <h1 class="text-xl mb-3">{t.cv.title}</h1>
    {t.cv.description(years).map((text) => (
      <p>{text}</p>
    ))}
  </div>
</div>
