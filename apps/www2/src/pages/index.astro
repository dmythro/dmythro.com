---
// Root redirect — detect locale and redirect
---

<html>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content="0;url=/en/" />
    <script is:inline>
      const lang = navigator.language?.startsWith('uk') ? 'uk' : 'en'
      window.location.replace('/' + lang + '/')
    </script>
  </head>
  <body />
</html>
