---
import { BASE_URL, ESocialLinks, USERNAME } from '@dmythro/constants'
import CvArticle from '@/components/CvArticle.astro'
import CvToc from '@/components/CvToc.astro'
import PageHeader from '@/components/PageHeader.astro'
import PhotoCard from '@/components/PhotoCard.astro'
import PageLayout from '@/layouts/PageLayout.astro'
import { getT } from '@/utils/getT'
import { getStaticLocalePaths, type LocaleCode } from '@/utils/i18n'

export function getStaticPaths() {
  return getStaticLocalePaths()
}

const { locale } = Astro.params as { locale: LocaleCode }
const t = getT(locale)
const years = new Date().getFullYear() - 2006
const cvDescription = t.cv.description(years).join(' ')

const cvJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  mainEntity: {
    '@type': 'Person',
    name: t.fullName,
    url: BASE_URL,
    jobTitle: 'Principal Engineer / Tech Lead',
    sameAs: [
      ESocialLinks.github,
      ESocialLinks.linkedin,
      ESocialLinks.bluesky,
      ESocialLinks.threads,
      ESocialLinks.twitter,
    ],
  },
}
---

<PageLayout
  locale={locale}
  title={`CV: ${t.fullName} — ${USERNAME}`}
  description={cvDescription}
  jsonLd={cvJsonLd}
  fullWidth
>
  <div class="flex gap-8 md:gap-10 print:block">
    {/* Sticky sidebar: photo + ToC */}
    <aside class="hidden md:block w-[250px] shrink-0 sticky top-20 self-start print:hidden" aria-label="CV sidebar">
      <PhotoCard locale={locale} />
      <div class="mt-4">
        <a
          href={`/cv.${locale}.pdf`}
          class="btn btn-outline btn-sm w-full"
          download
          data-cv-download={locale}
        >
          {t.actions.downloadPdf}
        </a>
      </div>
      <div class="mt-6">
        <CvToc locale={locale} />
      </div>
    </aside>

    {/* Main content */}
    <div class="flex-1 min-w-0 print:block">
      {/* Print-only photo */}
      <div class="hidden print:block print:max-w-[60%] print:mx-auto print:mb-6">
        <PhotoCard locale={locale} />
      </div>

      <PageHeader title={`CV — ${t.fullName}`} subtitle={t.meta.descriptionShort} />

      <CvArticle locale={locale} />
    </div>
  </div>
  <script>
    function setupCvTracking() {
      const downloadLink = document.querySelector<HTMLAnchorElement>('[data-cv-download]')
      if (downloadLink) {
        downloadLink.addEventListener('click', () => {
          window.zaraz?.track('cv_download', { locale: downloadLink.dataset.cvDownload })
        })
      }

      window.addEventListener('beforeprint', () => {
        window.zaraz?.track('cv_print')
      })
    }

    document.addEventListener('astro:page-load', setupCvTracking)
  </script>
</PageLayout>
