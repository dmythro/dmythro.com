---
import { ESocialLinks, USERNAME } from '@dmythro/constants'
import { CodeXml, Globe, Languages } from '@lucide/astro'
import {
  Astro as AstroIcon,
  Biome,
  Bun,
  Cloudflarepages,
  Daisyui,
  Github,
  Heroui,
  Nextdotjs,
  Nodedotjs,
  Preact,
  React,
  Tailwindcss,
  Turborepo,
  Typescript,
  Vercel,
} from 'simple-icons-astro'
import BackLink from '@/components/BackLink.astro'
import PageLayout from '@/layouts/PageLayout.astro'
import { getT } from '@/utils/getT'
import { getStaticLocalePaths, type LocaleCode } from '@/utils/i18n'

export function getStaticPaths() {
  return getStaticLocalePaths()
}

const { locale } = Astro.params as { locale: LocaleCode }
const t = getT(locale)

const iconClass = 'size-4 inline-block align-[-2px] mr-1.5 opacity-60'
const tb = t.builtWithTable
---

<PageLayout locale={locale} title={`${t.builtWithTitle} — ${USERNAME}`} description={t.builtWithDescription}>
  <div class="flex items-center gap-1 mb-6">
    <BackLink href={`/${locale}`} label={t.nav.home} />
    <h1 class="text-3xl font-bold" transition:name="page-title">{t.builtWithTitle}</h1>
  </div>

  <p class="prose max-w-none mb-8">
    {t.builtWithIntro}{' '}
    <a href={`${ESocialLinks.github}/dmythro.com`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1">
      GitHub <Github class="h-3.5 w-3.5" />
    </a>.{' '}
    {t.builtWithIntroAfter}{' '}
    <a href={`/${locale}/projects`} class="link">{t.builtWithProjectsCta}</a>
  </p>

  <div class="overflow-x-auto">
        <table class="table table-zebra">
          <thead>
            <tr>
              <th>{tb.category}</th>
              <th>v2 (2026)</th>
              <th>{tb.v1}</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>{tb.framework}</td>
              <td><a href="https://astro.build" target="_blank" rel="noopener noreferrer"><AstroIcon class={iconClass} />Astro 6</a></td>
              <td><a href="https://nextjs.org" target="_blank" rel="noopener noreferrer"><Nextdotjs class={iconClass} />Next.js 16</a></td>
            </tr>
            <tr>
              <td>{tb.uiLibrary}</td>
              <td><a href="https://daisyui.com" target="_blank" rel="noopener noreferrer"><Daisyui class={iconClass} />DaisyUI 5</a> (CSS-only)</td>
              <td><a href="https://heroui.com" target="_blank" rel="noopener noreferrer"><Heroui class={iconClass} />HeroUI 2.x</a> (React)</td>
            </tr>
            <tr>
              <td>{tb.styling}</td>
              <td colspan="2"><a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer"><Tailwindcss class={iconClass} />Tailwind CSS 4</a></td>
            </tr>
            <tr>
              <td>{tb.language}</td>
              <td colspan="2"><a href="https://www.typescriptlang.org" target="_blank" rel="noopener noreferrer"><Typescript class={iconClass} />TypeScript</a> (strict)</td>
            </tr>
            <tr>
              <td>{tb.interactivity}</td>
              <td><a href="https://preactjs.com" target="_blank" rel="noopener noreferrer"><Preact class={iconClass} />Preact</a> islands + <CodeXml class={iconClass} />vanilla JS</td>
              <td><a href="https://react.dev" target="_blank" rel="noopener noreferrer"><React class={iconClass} />React</a> SPA</td>
            </tr>
            <tr>
              <td>{tb.transitions}</td>
              <td><a href="https://docs.astro.build/en/guides/view-transitions/" target="_blank" rel="noopener noreferrer"><Globe class={iconClass} />View Transitions API</a></td>
              <td>{tb.notUsed}</td>
            </tr>
            <tr>
              <td>{tb.runtime}</td>
              <td><a href="https://bun.sh" target="_blank" rel="noopener noreferrer"><Bun class={iconClass} />Bun</a></td>
              <td><a href="https://nodejs.org" target="_blank" rel="noopener noreferrer"><Nodedotjs class={iconClass} />Node.js</a></td>
            </tr>
            <tr>
              <td>{tb.deployment}</td>
              <td><a href="https://pages.cloudflare.com" target="_blank" rel="noopener noreferrer"><Cloudflarepages class={iconClass} />Cloudflare Pages</a></td>
              <td><a href="https://vercel.com" target="_blank" rel="noopener noreferrer"><Vercel class={iconClass} />Vercel</a></td>
            </tr>
            <tr>
              <td>{tb.monorepo}</td>
              <td colspan="2"><Bun class={iconClass} />Bun workspaces + <a href="https://turbo.build/repo" target="_blank" rel="noopener noreferrer"><Turborepo class={iconClass} />Turborepo</a></td>
            </tr>
            <tr>
              <td>{tb.linting}</td>
              <td colspan="2"><a href="https://biomejs.dev" target="_blank" rel="noopener noreferrer"><Biome class={iconClass} />Biome</a></td>
            </tr>
            <tr>
              <td>{tb.i18n}</td>
              <td colspan="2"><Languages class={iconClass} />English + Ukrainian</td>
            </tr>
          </tbody>
        </table>
  </div>

</PageLayout>
