---
import faqEn from '@dmythro/locales/mdx/faq.en.md?raw'
import faqUk from '@dmythro/locales/mdx/faq.uk.md?raw'

import PageLayout from '@/layouts/PageLayout.astro'
import { getT } from '@/utils/getT'
import { getStaticLocalePaths, type LocaleCode } from '@/utils/i18n'

export function getStaticPaths() {
  return getStaticLocalePaths()
}

const { locale } = Astro.params as { locale: LocaleCode }
const t = getT(locale)

const rawMd = locale === 'uk' ? faqUk : faqEn

type FaqItem = { question: string; answer: string }

const faqItems: FaqItem[] = rawMd
  .split(/^## /m)
  .filter(Boolean)
  .map((block) => {
    const [question, ...rest] = block.split('\n')
    const answer = rest.join('\n').trim()
    return { question: question.trim(), answer }
  })
---

<PageLayout locale={locale} title={t.interests.faq.title} description={t.interests.faq.title}>
  <div class="max-w-2xl mx-auto">
    <h1 class="text-3xl font-bold mb-6">{t.interests.faq.title}</h1>
    <div class="flex flex-col gap-2">
      {faqItems.map(({ question, answer }, i) => (
        <div class="collapse collapse-arrow bg-base-100 border border-base-300 print:collapse-open">
          <input type="radio" name="faq-page" checked={i === 0} />
          <div class="collapse-title font-medium">{question}</div>
          <div class="collapse-content">
            <div class="prose prose-sm max-w-none" set:html={answer.replace(/\n\n/g, '<br><br>').replace(/`([^`]+)`/g, '<code>$1</code>')} />
          </div>
        </div>
      ))}
    </div>
  </div>
</PageLayout>
