---
import { ESocialLinks } from '@dmythro/constants'
import { Hash, Linkedin as LucideLinkedin } from '@lucide/astro'
import { Bluesky, Facebook, Github, Instagram, Telegram, Threads, X } from 'simple-icons-astro'

import PageLayout from '@/layouts/PageLayout.astro'
import { getT } from '@/utils/getT'
import { getStaticLocalePaths, type LocaleCode } from '@/utils/i18n'

export function getStaticPaths() {
  return getStaticLocalePaths()
}

const { locale } = Astro.params as { locale: LocaleCode }
const t = getT(locale)

const workLinks = [
  {
    title: 'GitHub',
    href: ESocialLinks.github,
    description: t.socialMedia[ESocialLinks.github],
    Icon: Github,
    color: 'currentColor',
  },
  {
    title: 'LinkedIn',
    href: ESocialLinks.linkedin,
    description: t.socialMedia[ESocialLinks.linkedin],
    Icon: LucideLinkedin,
    color: '#0A66C2',
  },
]

const directLinks = [
  {
    title: 'Telegram',
    href: ESocialLinks.telegram,
    description: t.socialMedia[ESocialLinks.telegram],
    Icon: Telegram,
    color: '#26A5E4',
  },
]

const personalLinks = [
  {
    title: 'BlueSky',
    href: ESocialLinks.bluesky,
    description: t.socialMedia[ESocialLinks.bluesky],
    Icon: Bluesky,
    color: '#0285FF',
  },
  {
    title: 'Threads',
    href: ESocialLinks.threads,
    description: t.socialMedia[ESocialLinks.threads],
    Icon: Threads,
    color: 'currentColor',
  },
  {
    title: 'Instagram',
    href: ESocialLinks.instagram,
    description: t.socialMedia[ESocialLinks.instagram],
    Icon: Instagram,
    color: '#E4405F',
  },
  {
    title: 'Facebook',
    href: ESocialLinks.facebook,
    description: t.socialMedia[ESocialLinks.facebook],
    Icon: Facebook,
    color: '#0866FF',
  },
  {
    title: 'X / Twitter',
    href: ESocialLinks.twitter,
    description: t.socialMedia[ESocialLinks.twitter],
    Icon: X,
    color: 'currentColor',
  },
  {
    title: 'Nostr',
    href: ESocialLinks.nostr,
    description: t.socialMedia[ESocialLinks.nostr],
    Icon: Hash,
    color: '#8B5CF6',
  },
]

type LinkItem = {
  title: string
  href: string
  description: string
  Icon: typeof Github
  color: string
}

const sections: { heading: string; links: LinkItem[] }[] = [
  { heading: t.socialMedia.work, links: workLinks },
  { heading: t.contact.directContact, links: directLinks },
  { heading: t.socialMedia.personal, links: personalLinks },
]
---

<PageLayout locale={locale} title={t.contact.title} description={t.contact.subtitle}>
  <div>
    <h1 class="text-3xl font-bold mb-2">{t.contact.title}</h1>
    <p class="text-(-color-content-secondary) mb-8">{t.contact.subtitle}</p>

    {sections.map(({ heading, links }) => (
      <section class="mb-8">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-content-muted)] mb-3">
          {heading}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {links.map(({ title, href, description, Icon, color }) => (
            <a
              href={href}
              target="_blank"
              rel="me noopener noreferrer"
              class="group flex items-center gap-4 p-4 rounded-xl border border-base-300 bg-base-100 hover:bg-base-200 transition-colors"
            >
              <div class="shrink-0">
                <Icon class="h-10 w-10" style={`color: ${color}`} />
              </div>
              <div class="flex-1 min-w-0">
                <div class="font-medium">{title}</div>
                <div class="text-sm text-(-color-content-secondary) truncate">{description}</div>
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</PageLayout>
