---
import { BASE_URL, ESocialLinks, USERNAME } from '@dmythro/constants'
import type { Person, WithContext } from 'schema-dts'
import Hero from '@/components/Hero.astro'
import SectionBeyondCode from '@/components/SectionBeyondCode.astro'
import SectionTldr from '@/components/SectionTldr.astro'
import SectionWork from '@/components/SectionWork.astro'
import { getHighlightedProjects } from '@/data/projects'
import PageLayout from '@/layouts/PageLayout.astro'
import { fetchAggregateStats } from '@/utils/fetchAggregateStats'
import { fetchGithubStats } from '@/utils/fetchGithubStats'
import { fetchNpmStats } from '@/utils/fetchNpmStats'
import { getT } from '@/utils/getT'
import { getStaticLocalePaths, type LocaleCode } from '@/utils/i18n'

export function getStaticPaths() {
  return getStaticLocalePaths()
}

const { locale } = Astro.params as { locale: LocaleCode }
const t = getT(locale)

const stats = await fetchAggregateStats()
const highlightedProjects = getHighlightedProjects()
const projectStats = await Promise.all(
  highlightedProjects.map(async (project) => ({
    project,
    npm: project.npm ? await fetchNpmStats(project.npmForDownloads ?? project.npm) : null,
    github: project.github ? await fetchGithubStats(project.github, project.fallbackStars) : null,
  })),
)

const personJsonLd: WithContext<Person> = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: t.fullName,
  url: BASE_URL,
  jobTitle: 'Principal Engineer / Tech Lead',
  image: `${BASE_URL}/avatar@og.jpg`,
  knowsAbout: [
    'Web Development',
    'TypeScript',
    'React',
    'Node.js',
    'JavaScript',
    'Next.js',
    'GraphQL',
    'Astro',
    'Bun',
    'Vite',
    'Tailwind CSS',
    'PostgreSQL',
    'MySQL',
    'Redis',
    'AI',
    'Frontend Architecture',
    'Open Source',
    'Team Leadership',
    'Software Engineering',
    'CI/CD',
  ],
  sameAs: [
    ESocialLinks.github,
    ESocialLinks.linkedin,
    ESocialLinks.facebook,
    ESocialLinks.instagram,
    ESocialLinks.bluesky,
    ESocialLinks.threads,
    ESocialLinks.twitter,
  ],
}
---

<PageLayout
  locale={locale}
  title={USERNAME}
  description={t.meta.description}
  jsonLd={personJsonLd as unknown as Record<string, unknown>}
  isHeroPage={true}
>
  <Hero locale={locale} slot="hero" />

  <SectionTldr locale={locale} stats={stats} />
  <SectionBeyondCode locale={locale} />
  <SectionWork locale={locale} projects={projectStats} />
</PageLayout>
