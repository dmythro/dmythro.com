---
import PageLayout from '@/layouts/PageLayout.astro'
import Hero from '@/components/Hero.astro'
import SupportUkraineCard from '@/components/SupportUkraineCard.astro'
import SectionAccordion from '@/components/SectionAccordion.astro'
import { getStaticLocalePaths, type LocaleCode } from '@/utils/i18n'
import { getT } from '@/utils/getT'
import { BASE_URL, ESocialLinks, USERNAME } from 'my-constants'
import type { Person, WithContext } from 'schema-dts'

export function getStaticPaths() {
  return getStaticLocalePaths()
}

const { locale } = Astro.params as { locale: LocaleCode }
const t = getT(locale)

const personJsonLd: WithContext<Person> = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: t.fullName,
  url: BASE_URL,
  sameAs: [
    ESocialLinks.github,
    ESocialLinks.linkedin,
    ESocialLinks.facebook,
    ESocialLinks.instagram,
    ESocialLinks.bluesky,
    ESocialLinks.threads,
    ESocialLinks.twitter,
  ],
}
---

<PageLayout
  locale={locale}
  title={`${USERNAME} — ${t.meta.descriptionShort}`}
  description={t.meta.description}
  jsonLd={personJsonLd as unknown as Record<string, unknown>}
  isHeroPage={true}
>
  <Hero locale={locale} slot="hero" />

  <div class="flex flex-col sm:flex-row-reverse gap-6 md:gap-8 print:flex-col print:block">
    {/* Sidebar */}
    <div class="basis-full sm:basis-4/12 sm:sticky sm:self-start sm:top-20 print:relative print:top-auto">
      <div class="flex flex-col gap-4 print:block">
        <SupportUkraineCard locale={locale} />
      </div>
    </div>

    {/* Main content: accordion sections */}
    <div class="basis-full sm:basis-8/12 print:block">
      <SectionAccordion locale={locale} />
    </div>
  </div>
</PageLayout>
