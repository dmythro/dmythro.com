---

import { BASE_URL, USERNAME } from '@dmythro/constants'
import PageHeader from '@/components/PageHeader.astro'
import ProjectCard from '@/components/ProjectCard.astro'
import { getProjectsByCategory } from '@/data/projects'
import PageLayout from '@/layouts/PageLayout.astro'
import { fetchGithubStats } from '@/utils/fetchGithubStats'
import { fetchNpmStats } from '@/utils/fetchNpmStats'
import { getT } from '@/utils/getT'
import { getStaticLocalePaths, type LocaleCode } from '@/utils/i18n'

export function getStaticPaths() {
  return getStaticLocalePaths()
}

const { locale } = Astro.params as { locale: LocaleCode }
const t = getT(locale)
const ALL = 'all'
const allProjects = getProjectsByCategory()
const projectStats = await Promise.all(
  allProjects.map(async (project) => ({
    project,
    npm: project.npm ? await fetchNpmStats(project.npmForDownloads ?? project.npm) : null,
    github: project.github ? await fetchGithubStats(project.github, project.fallbackStars) : null,
  })),
)
const categories = [ALL, ...new Set(allProjects.map((p) => p.category))]
const categoryLabels: Record<string, string> = Object.fromEntries(
  categories
    .filter((cat) => cat in t.projects.categories)
    .map((cat) => [cat, t.projects.categories[cat as keyof typeof t.projects.categories]]),
)
const showCategoryTabs = categories.length > 2

const projectsJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: t.projects.title,
  description: t.projects.description,
  url: `${BASE_URL}/${locale}/projects`,
  author: { '@type': 'Person', name: 'Dmytro Klymenko', url: BASE_URL },
}
---

<PageLayout
  locale={locale}
  title={`${t.projects.title} — ${USERNAME}`}
  description={t.projects.description}
  jsonLd={projectsJsonLd}
>
  <PageHeader title={t.projects.title} subtitle={t.projects.description} />

  {/* Category tabs — only show when multiple categories exist */}
  {showCategoryTabs && (
    <div role="tablist" class="tabs tabs-box mb-6">
      {categories.map((cat) => (
        <button
          role="tab"
          class:list={['tab', { 'tab-active': cat === ALL }]}
          data-category={cat}
        >
          {categoryLabels[cat]}
        </button>
      ))}
    </div>
  )}

  {/* Project grid */}
  <div class="columns-1 sm:columns-2 lg:columns-3 gap-4 [&>div]:mb-4" id="projects-grid">
    {projectStats.map(({ project, npm, github }) => (
      <div class="break-inside-avoid" data-category={project.category}>
        <ProjectCard project={project} locale={locale} npm={npm} github={github} />
      </div>
    ))}
  </div>

  {/* Client-side filtering */}
  <script is:inline>
    document.addEventListener('astro:page-load', () => {
      document.querySelectorAll('[role="tab"]').forEach(tab => {
        tab.addEventListener('click', () => {
          document.querySelectorAll('[role="tab"]').forEach(t => t.classList.remove('tab-active'))
          tab.classList.add('tab-active')
          const cat = tab.dataset.category
          document.querySelectorAll('#projects-grid > div').forEach(card => {
            card.style.display = (cat === 'all' || card.dataset.category === cat) ? '' : 'none'
          })
        })
      })
    })
  </script>
</PageLayout>
