---
import PageLayout from '@/layouts/PageLayout.astro'
import ProjectCard from '@/components/ProjectCard.astro'
import { getProjectsByCategory, type ProjectCategory } from '@/data/projects'
import { getStaticLocalePaths, type LocaleCode } from '@/utils/i18n'
import { getT } from '@/utils/getT'

export function getStaticPaths() {
  return getStaticLocalePaths()
}

const { locale } = Astro.params as { locale: LocaleCode }
const t = getT(locale)
const allProjects = getProjectsByCategory()
const categories: (ProjectCategory | undefined)[] = [undefined, 'dev', 'music', 'photos']
const categoryLabels: Record<string, string> = {
  undefined: t.projects.categories.all,
  dev: t.projects.categories.dev,
  music: t.projects.categories.music,
  photos: t.projects.categories.photos,
}
const uniqueCategories = new Set(allProjects.map((p) => p.category))
const showCategoryTabs = uniqueCategories.size > 1
---

<PageLayout
  locale={locale}
  title={`${t.projects.title} — ${t.name}`}
  description={t.projects.description}
>
  <h1 class="text-3xl font-bold mb-2">{t.projects.title}</h1>
  <p class="text-base-content/60 mb-8">{t.projects.description}</p>

  {/* Category tabs — only show when multiple categories exist */}
  {showCategoryTabs && (
    <div role="tablist" class="tabs tabs-box mb-6">
      {categories.map((cat) => (
        <button
          role="tab"
          class:list={['tab', { 'tab-active': cat === undefined }]}
          data-category={cat || 'all'}
        >
          {categoryLabels[String(cat)]}
        </button>
      ))}
    </div>
  )}

  {/* Project grid */}
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" id="projects-grid">
    {allProjects.map((project) => (
      <div data-category={project.category}>
        <ProjectCard project={project} locale={locale} />
      </div>
    ))}
  </div>

  {/* Client-side filtering */}
  <script is:inline>
    document.querySelectorAll('[role="tab"]').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('[role="tab"]').forEach(t => t.classList.remove('tab-active'))
        tab.classList.add('tab-active')
        const cat = tab.dataset.category
        document.querySelectorAll('#projects-grid > div').forEach(card => {
          card.style.display = (cat === 'all' || card.dataset.category === cat) ? '' : 'none'
        })
      })
    })
  </script>
</PageLayout>
