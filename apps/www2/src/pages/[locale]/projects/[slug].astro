---
import { Camera, ExternalLink, Github, Globe, Music, Package, Terminal } from '@lucide/astro'

import PageLayout from '@/layouts/PageLayout.astro'
import ProjectCard from '@/components/ProjectCard.astro'
import ProjectStats from '@/components/ProjectStats.astro'
import { projects, getHighlightedProjects } from '@/data/projects'
import { availableLocales, type LocaleCode } from '@/utils/i18n'
import { getT } from '@/utils/getT'
import { fetchNpmStats } from '@/utils/fetchNpmStats'
import { fetchGithubStats } from '@/utils/fetchGithubStats'

export function getStaticPaths() {
  return projects.flatMap((project) =>
    availableLocales.map((locale) => ({
      params: { locale, slug: project.slug },
      props: { project },
    })),
  )
}

const { locale, slug } = Astro.params as { locale: LocaleCode; slug: string }
const { project } = Astro.props
const t = getT(locale)
const title = project.title[locale]
const description = project.description[locale]

// Fetch stats at build time (parallel)
const [npmStats, githubStats] = await Promise.all([
  project.npm ? fetchNpmStats(project.npm) : null,
  project.github ? fetchGithubStats(project.github, project.fallbackStars) : null,
])

// Load project article content
const mdxFiles = import.meta.glob('../../../../../../packages/locales/mdx/projects/*.md', {
  eager: true,
}) as Record<string, { compiledContent(): string }>

const mdxKey = Object.keys(mdxFiles).find((k) => k.endsWith(`/${slug}.${locale}.md`))
const articleHtml = mdxKey ? mdxFiles[mdxKey].compiledContent() : null

const iconMap = {
  package: Package,
  globe: Globe,
  terminal: Terminal,
  music: Music,
  camera: Camera,
} as const
const IconComponent = iconMap[project.icon as keyof typeof iconMap]

// Other highlighted projects for cross-linking
const otherProjects = getHighlightedProjects()
  .filter((p) => p.slug !== project.slug)
  .slice(0, 3)
---

<PageLayout locale={locale} title={`${title} — ${t.name}`} description={description}>
  <article>
    <div class="mb-6">
      <h1 class="text-3xl font-bold mb-2 flex items-center gap-2">
        {IconComponent && <IconComponent class="h-7 w-7 shrink-0 opacity-60" />}
        <span class="mr-2">{title}</span>
        {project.url && (
          <a href={project.url} class="tooltip tooltip-bottom tooltip-primary" data-tip="Visit site" aria-label="Visit site" target="_blank" rel="noopener noreferrer">
            <ExternalLink class="h-5 w-5 opacity-50 hover:opacity-100 transition-opacity" />
          </a>
        )}
        {project.github && (
          <a href={`https://github.com/${project.github}`} class="tooltip tooltip-bottom tooltip-primary" data-tip="GitHub" aria-label="GitHub repository" target="_blank" rel="noopener noreferrer">
            <Github class="h-5 w-5 opacity-50 hover:opacity-100 transition-opacity" />
          </a>
        )}
        {project.npm && (
          <a href={`https://www.npmjs.com/package/${project.npm}`} class="tooltip tooltip-bottom tooltip-primary" data-tip="NPM" aria-label="NPM package" target="_blank" rel="noopener noreferrer">
            <Package class="h-5 w-5 opacity-50 hover:opacity-100 transition-opacity" />
          </a>
        )}
      </h1>
      <p class="text-lg text-base-content/70 mb-4">{description}</p>

      <div class="flex flex-wrap items-center gap-2">
        <ProjectStats
          npmDownloads={npmStats?.downloads}
          githubStars={githubStats?.stars}
        />
        {project.tags.map((tag) => (
          <span class="badge badge-sm badge-soft">{tag}</span>
        ))}
      </div>
    </div>

    {articleHtml && (
      <div class="prose max-w-none mt-6" set:html={articleHtml} />
    )}
  </article>

  {/* Other projects */}
  {otherProjects.length > 0 && (
    <section class="mt-12">
      <h2 class="text-2xl font-semibold mb-4">
        {t.projects.otherProjects}
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {otherProjects.map((p) => (
          <ProjectCard project={p} locale={locale} />
        ))}
      </div>
    </section>
  )}
</PageLayout>
